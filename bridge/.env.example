# Copy to .env and adjust. All optional except when noted.
PORT=8787

# Coach model. Opus for quality (the user wants Opus).
COACH_MODEL=claude-opus-4-8

# Full path to the claude binary. Needed when run under launchd (no login PATH).
CLAUDE_BIN=/Users/max/.local/bin/claude

# Browser origins allowed to call the bridge (comma-separated).
ALLOWED_ORIGINS=https://trainer.azurecarson.com,http://localhost:4173

# Optional shared token. If set, clients must send it as `x-bridge-token`.
# Defense in depth behind Cloudflare Access. Leave blank to allow any allowed-origin caller.
BRIDGE_TOKEN=
